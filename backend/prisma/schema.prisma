datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id               Int            @id @default(autoincrement())
  email            String         @unique
  password         String
  role             String         // "patient", "doctor", "admin"
  name             String
  createdAt        DateTime       @default(now()) @map("created_at")
  patient          Patient?
  doctor           Doctor?
  notifications    Notification[]
  sentMessages     Message[]      @relation("SentMessages")
  receivedMessages Message[]      @relation("ReceivedMessages")

  @@map("users")
}

model Patient {
  id               Int             @id @default(autoincrement())
  userId           Int             @unique @map("user_id")
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  dob              DateTime        @db.Date
  gender           String
  contact          String?
  insurance        String?
  medicalHistory   String?         @map("medical_history")
  bloodGroup       String?         @map("blood_group")
  emergencyContact String?         @map("emergency_contact")
  allergies        String?
  createdAt        DateTime        @default(now()) @map("created_at")
  appointments     Appointment[]
  medicalRecords   MedicalRecord[]

  @@map("patients")
}

model Doctor {
  id             Int            @id @default(autoincrement())
  userId         Int            @unique @map("user_id")
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  specialization String
  experience     Int            @default(1)
  fee            Decimal        @db.Decimal(10, 2)
  rating         Decimal        @default(5.0) @db.Decimal(2, 1)
  location       String
  licenseNumber  String         @unique @map("license_number")
  status         String         @default("pending") // "pending", "approved", "rejected"
  qualifications String
  bio            String?
  createdAt      DateTime       @default(now()) @map("created_at")
  appointments   Appointment[]
  reviews        Review[]
  timeSlots      TimeSlot[]

  @@map("doctors")
}

model TimeSlot {
  id          Int          @id @default(autoincrement())
  doctorId    Int          @map("doctor_id")
  doctor      Doctor       @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  date        DateTime     @db.Date
  timeSlot    String       @map("time_slot")
  isBooked    Boolean      @default(false) @map("is_booked")
  appointment Appointment?

  @@unique([doctorId, date, timeSlot])
  @@map("time_slots")
}

model Appointment {
  id            Int            @id @default(autoincrement())
  patientId     Int            @map("patient_id")
  patient       Patient        @relation(fields: [patientId], references: [id], onDelete: Cascade)
  doctorId      Int            @map("doctor_id")
  doctor        Doctor         @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  timeSlotId    Int?           @unique @map("time_slot_id")
  timeSlot      TimeSlot?      @relation(fields: [timeSlotId], references: [id], onDelete: SetNull)
  date          DateTime       @db.Date
  status        String         @default("pending") // "pending", "approved", "cancelled", "completed"
  fee           Decimal        @db.Decimal(10, 2)
  paymentStatus String         @default("unpaid") @map("payment_status") // "unpaid", "paid", "refunded"
  createdAt     DateTime       @default(now()) @map("created_at")
  prescription  Prescription?
  payments      Payment[]
  videoSessions VideoSession[]

  @@map("appointments")
}

model Prescription {
  id            Int         @id @default(autoincrement())
  appointmentId Int         @unique @map("appointment_id")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  medications   String
  notes         String?
  date          DateTime    @default(now()) @db.Date

  @@map("prescriptions")
}

model MedicalRecord {
  id         Int      @id @default(autoincrement())
  patientId  Int      @map("patient_id")
  patient    Patient  @relation(fields: [patientId], references: [id], onDelete: Cascade)
  reportName String   @map("report_name")
  category   String
  uploadDate DateTime @default(now()) @map("upload_date") @db.Date
  status     String   @default("verified") // "pending", "verified"
  filePath   String   @map("file_path")

  @@map("medical_records")
}

model Payment {
  id            Int         @id @default(autoincrement())
  appointmentId Int         @map("appointment_id")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  amount        Decimal     @db.Decimal(10, 2)
  method        String
  transactionId String      @unique @map("transaction_id")
  status        String      @default("success") // "success", "failed"
  date          DateTime    @default(now()) @db.Date

  @@map("payments")
}

model Review {
  id          Int      @id @default(autoincrement())
  doctorId    Int      @map("doctor_id")
  doctor      Doctor   @relation(fields: [doctorId], references: [id], onDelete: Cascade)
  patientName String   @map("patient_name")
  rating      Int
  comment     String?
  date        DateTime @default(now()) @db.Date

  @@map("reviews")
}

model Notification {
  id       Int      @id @default(autoincrement())
  userId   Int      @map("user_id")
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  message  String
  isRead   Boolean  @default(false) @map("is_read")
  date     DateTime @default(now()) @db.Date

  @@map("notifications")
}

model Message {
  id         Int      @id @default(autoincrement())
  senderId   Int      @map("sender_id")
  sender     User     @relation("SentMessages", fields: [senderId], references: [id], onDelete: Cascade)
  receiverId Int      @map("receiver_id")
  receiver   User     @relation("ReceivedMessages", fields: [receiverId], references: [id], onDelete: Cascade)
  content    String
  sentAt     DateTime @default(now()) @map("sent_at")

  @@map("messages")
}

model VideoSession {
  id            Int         @id @default(autoincrement())
  appointmentId Int         @map("appointment_id")
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  channelName   String      @map("channel_name")
  token         String?
  isActive      Boolean     @default(true) @map("is_active")
  createdAt     DateTime    @default(now()) @map("created_at")

  @@map("video_sessions")
}
